# Database
DATABASE_URL=postgresql://postgres:senha123@localhost:5432/hidrometro_brk
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=senha123

# Azure Computer Vision
AZURE_VISION_ENDPOINT=https://xxxxx.cognitiveservices.azure.com/
AZURE_VISION_KEY=sua-chave-aqui

# JWT
JWT_SECRET=sua-secret-super-segura-minimo-32-chars-aqui
JWT_EXPIRATION_HOURS=8

# Azure Blob Storage (Backup)
AZURE_STORAGE_ACCOUNT=sua-conta
AZURE_STORAGE_KEY=sua-chave
AZURE_STORAGE_CONTAINER=fotos-hidrometro

# Backup Local (rede)
BACKUP_LOCAL_PATH=\\rede-empresa\backup-hidrometro\

# Logging
LOG_LEVEL=Information
LOG_PATH=./storage/logs/app.log

# Environment
ENVIRONMENT=Development
