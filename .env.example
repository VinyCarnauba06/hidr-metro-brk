# Database
DATABASE_URL=postgresql://postgres:senha123@localhost:5432/hidrometro_brk
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=senha123

# Google Gemini Vision (OCR de hidrômetros)
# Deixe vazio para ativar modo simulado (padrão em dev)
GEMINI_API_KEY=

# Google Cloud Storage (armazenamento de fotos)
# Nome do bucket GCS — ex: hidrometro-fotos-prod
# Requer GOOGLE_APPLICATION_CREDENTIALS (caminho para Service Account JSON) ou Workload Identity em GCP
GCS_BUCKET_NAME=

# Google SSO
# Client ID do OAuth 2.0 criado no Google Cloud Console (tipo "Web application")
# Deixe vazio para desabilitar validação de audience (não recomendado em produção)
GOOGLE_CLIENT_ID=

# JWT
JWT_SECRET=sua-secret-super-segura-minimo-32-chars-aqui
JWT_EXPIRATION_HOURS=8

# Logging
LOG_LEVEL=Information
LOG_PATH=./storage/logs/app.log

# Environment
ENVIRONMENT=Development
