# Database
DATABASE_URL=postgresql://postgres:senha123@localhost:5432/hidrometro_brk
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=senha123

# Google Gemini Vision (OCR de hidrômetros)
# Deixe vazio para ativar modo simulado (padrão em dev)
GEMINI_API_KEY=

# Google Cloud Storage (armazenamento de fotos)
# Nome do bucket GCS — ex: hidrometro-fotos-prod
# Vazio = usa filesystem local (STORAGE_PATH). Setado = ativa GcsFotoStorage.
GCS_BUCKET_NAME=

# Caminho absoluto para o Service Account JSON usado pelo GcsFotoStorage.
# Necessário apenas se GCS_BUCKET_NAME estiver setado e a máquina não tiver Workload Identity (GCE/GKE/Cloud Run).
# Windows: defina a env var do processo (NSSM AppEnvironmentExtra), não um arquivo .env — StorageClient.Create() lê via ADC.
GOOGLE_APPLICATION_CREDENTIALS=

# Diretório para fotos quando GCS_BUCKET_NAME está vazio (fallback local)
STORAGE_PATH=

# Google SSO
# Client ID do OAuth 2.0 criado no Google Cloud Console (tipo "Web application")
# Deixe vazio para desabilitar validação de audience (não recomendado em produção)
GOOGLE_CLIENT_ID=

# JWT
JWT_SECRET=sua-secret-super-segura-minimo-32-chars-aqui
JWT_EXPIRATION_HOURS=8

# Logging
LOG_LEVEL=Information
LOG_PATH=./storage/logs/app.log

# Environment
ENVIRONMENT=Development
