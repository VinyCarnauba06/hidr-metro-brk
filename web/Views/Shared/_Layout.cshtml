@{
    var isAuth    = User.Identity?.IsAuthenticated == true;
    var userName  = isAuth ? (User.Identity?.Name ?? "Usuário") : "";
    var userRole  = isAuth
        ? (User.IsInRole("Admin") ? "Admin" : User.IsInRole("Operador") ? "Operador" : "Fiscal")
        : "";

    var initials  = "U";
    if (isAuth && userName.Length > 0)
    {
        var parts = userName.Split(' ');
        initials = parts[0][0].ToString().ToUpper();
        if (parts.Length > 1 && parts[1].Length > 0)
            initials += parts[1][0].ToString().ToUpper();
    }

    var path = Context.Request.Path.Value ?? "";

    string NavCls(bool active) => active
        ? "flex items-center gap-3 px-3 py-2.5 rounded-lg mb-0.5 text-sm font-semibold bg-hcard text-hbrk"
        : "flex items-center gap-3 px-3 py-2.5 rounded-lg mb-0.5 text-sm text-slate-400 hover:bg-hcard hover:text-slate-200 transition-colors duration-150";
}
<!DOCTYPE html>
<html lang="pt-BR" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — HIDRO</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        hbg:    '#0d0f14',
                        hsurf:  '#141720',
                        hcard:  '#1c2030',
                        hbrk:   '#00c9a7',
                        hrim:   '#1e2535',
                    },
                    fontFamily: {
                        syne: ['Syne', 'sans-serif'],
                        dm:   ['"DM Sans"', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        * { box-sizing: border-box; }
        a { text-decoration: none; }
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: #0d0f14; }
        ::-webkit-scrollbar-thumb { background: #1e2535; border-radius: 9999px; }
    </style>
</head>
<body class="bg-hbg font-dm text-slate-200 h-full">

@if (isAuth)
{
    <div class="flex h-screen overflow-hidden">

        <!-- ── Sidebar ───────────────────────────────────────── -->
        <aside class="w-64 bg-hsurf border-r border-hrim flex flex-col flex-shrink-0">

            <!-- Logo -->
            <div class="px-5 py-5 border-b border-hrim">
                <div class="flex items-center gap-2.5">
                    <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 bg-hbrk">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 2c-4 4.5-6 7.5-6 10a6 6 0 0012 0c0-2.5-2-5.5-6-10z"/>
                            <path d="M12 12v4"/>
                        </svg>
                    </div>
                    <span class="font-syne font-bold text-lg tracking-wide text-slate-100">
                        HIDRO<span class="text-hbrk">BRK</span>
                    </span>
                </div>
            </div>

            <!-- Nav -->
            <nav class="flex-1 px-3 py-4 overflow-y-auto">
                <p class="text-xs font-semibold text-slate-600 uppercase tracking-widest px-3 mb-3">Navegação</p>

                @if (User.IsInRole("Operador") || User.IsInRole("Admin"))
                {
                    <a href="/Operador" class="@NavCls(path.StartsWith("/Operador"))">
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
                        </svg>
                        Ordens de Serviço
                    </a>
                }

                @if (User.IsInRole("Admin"))
                {
                    <a href="/Admin/Dashboard" class="@NavCls(path == "/Admin/Dashboard" || path == "/Admin")">
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="12" width="5" height="9" rx="1"/>
                            <rect x="9.5" y="7" width="5" height="14" rx="1"/>
                            <rect x="16" y="3" width="5" height="18" rx="1"/>
                        </svg>
                        Dashboard
                    </a>
                    <a href="/Admin/Condominios" class="@NavCls(path.StartsWith("/Admin/Condominios"))">
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 21h18M5 21V7l8-4 8 4v14M9 21V9h6v12"/>
                        </svg>
                        Condomínios
                    </a>
                    <a href="/Admin/Usuarios" class="@NavCls(path.StartsWith("/Admin/Usuarios"))">
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
                        </svg>
                        Usuários
                    </a>
                    <a href="/Admin/Auditoria" class="@NavCls(path.StartsWith("/Admin/Auditoria"))">
                        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                        </svg>
                        Auditoria
                    </a>
                }
            </nav>

            <!-- User footer -->
            <div class="px-3 py-4 border-t border-hrim">
                <div class="flex items-center gap-2.5 mb-3 px-1">
                    <div class="w-9 h-9 rounded-full bg-hbrk flex items-center justify-center flex-shrink-0">
                        <span class="font-syne font-bold text-sm text-hbg">@initials</span>
                    </div>
                    <div class="min-w-0">
                        <p class="text-sm font-medium text-slate-200 truncate leading-tight">@userName</p>
                        <span class="text-xs text-hbrk font-medium">@userRole</span>
                    </div>
                </div>
                <form method="post" action="/Auth/Logout">
                    <button type="submit"
                        class="w-full flex items-center gap-2 px-3 py-2 rounded-lg text-slate-500 hover:text-slate-300 hover:bg-hcard text-sm transition-colors duration-150 border border-hrim cursor-pointer">
                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                        </svg>
                        Sair da conta
                    </button>
                </form>
            </div>

        </aside>
        <!-- ── /Sidebar ──────────────────────────────────────── -->

        <!-- ── Main content ──────────────────────────────────── -->
        <div class="flex-1 flex flex-col overflow-y-auto bg-hbg">
            <main class="flex-1 p-8">
                @RenderBody()
            </main>
            <footer class="text-center text-slate-700 text-xs py-4 border-t border-hrim">
                HIDRO &copy; @DateTime.Now.Year — Prolar AGE
            </footer>
        </div>
        <!-- ── /Main content ─────────────────────────────────── -->

    </div>
}
else
{
    @RenderBody()
}

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
