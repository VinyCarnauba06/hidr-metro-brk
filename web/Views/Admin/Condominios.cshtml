@{
    ViewData["Title"] = "Condomínios";
    var lista       = (IEnumerable<JsonElement>)Model;
    var erroViewBag = ViewBag.Erro as string;
    var erroPost    = TempData["Erro"] as string;
    var sucesso     = TempData["Sucesso"] as string;
}

@if (!string.IsNullOrEmpty(erroViewBag) || !string.IsNullOrEmpty(erroPost))
{
    <div class="bg-red-500/10 border border-red-500/30 rounded-xl px-4 py-3 mb-6 flex items-center gap-3">
        <svg class="w-5 h-5 text-red-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <p class="text-sm text-red-400">@(erroPost ?? erroViewBag)</p>
    </div>
}

@if (!string.IsNullOrEmpty(sucesso))
{
    <div class="bg-hbrk/10 border border-hbrk/30 rounded-xl px-4 py-3 mb-6 flex items-center gap-3">
        <svg class="w-5 h-5 text-hbrk shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
        <p class="text-sm text-hbrk">@sucesso</p>
    </div>
}

<div class="mb-6 flex items-end justify-between">
    <div>
        <h1 class="font-syne font-bold text-2xl text-slate-100">Condomínios</h1>
        <p class="text-slate-500 text-sm mt-1">@lista.Count() cadastrados</p>
    </div>
    <button id="btn-novo-condo"
        onclick="document.getElementById('form-novo-condo').classList.remove('hidden'); this.classList.add('hidden');"
        class="flex items-center gap-2 text-sm font-semibold px-4 py-2 rounded-lg border
               bg-hbrk/10 text-hbrk border-hbrk/30 hover:bg-hbrk hover:border-hbrk transition-colors cursor-pointer"
        onmouseover="this.style.color='#0d0f14'" onmouseout="this.style.color=''">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Novo Condomínio
    </button>
</div>

<form id="form-novo-condo" method="post" action="/Admin/CriarCondominio"
      class="hidden bg-hsurf border border-hrim rounded-2xl p-5 mb-6">
    <h3 class="font-syne font-semibold text-slate-100 mb-4">Novo Condomínio</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5">Nome *</label>
            <input name="nome" required type="text" placeholder="Residencial Exemplo"
                class="w-full bg-hcard border border-hrim rounded-lg px-3 py-2 text-sm text-slate-200 placeholder-slate-600
                       focus:outline-none focus:border-hbrk focus:ring-1 focus:ring-hbrk transition-colors" />
        </div>
        <div>
            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5">Endereço</label>
            <input name="endereco" type="text" placeholder="Rua Exemplo, 100 — Bairro"
                class="w-full bg-hcard border border-hrim rounded-lg px-3 py-2 text-sm text-slate-200 placeholder-slate-600
                       focus:outline-none focus:border-hbrk focus:ring-1 focus:ring-hbrk transition-colors" />
        </div>
        <div>
            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5">Total de Unidades *</label>
            <input name="qtdUnidades" required type="number" min="1" placeholder="ex: 40"
                class="w-full bg-hcard border border-hrim rounded-lg px-3 py-2 text-sm text-slate-200 placeholder-slate-600
                       focus:outline-none focus:border-hbrk focus:ring-1 focus:ring-hbrk transition-colors" />
            <p class="text-xs text-slate-600 mt-1">Ignorado se "Números das unidades" estiver preenchido — o total vem da lista.</p>
        </div>
        <div>
            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5">Tipo de Medidor *</label>
            <select name="tipoMedidor" required
                class="w-full bg-hcard border border-hrim rounded-lg px-3 py-2 text-sm text-slate-200
                       focus:outline-none focus:border-hbrk focus:ring-1 focus:ring-hbrk transition-colors appearance-none cursor-pointer">
                <option value="">Selecione...</option>
                <option value="AguaFria">Água Fria</option>
                <option value="AguaQuente">Água Quente</option>
                <option value="Gas">Gás</option>
            </select>
        </div>
        <div class="md:col-span-2">
            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5">
                Números das unidades (opcional — separa por vírgula, espaço ou linha)
            </label>
            <textarea name="numerosTexto" rows="3" placeholder="ex: 101, 102, 103, 104, 201, 202, 203, 204"
                class="w-full bg-hcard border border-hrim rounded-lg px-3 py-2 text-sm text-slate-200 placeholder-slate-600
                       focus:outline-none focus:border-hbrk focus:ring-1 focus:ring-hbrk transition-colors"></textarea>
            <p class="text-xs text-slate-600 mt-1">
                Deixe em branco pra gerar sequencial 001, 002... até o Total de Unidades.
                Preencha pra usar a numeração real do prédio (ex: por andar).
            </p>
        </div>
    </div>
    <div class="flex gap-2 mt-5">
        <button type="submit"
            class="px-4 py-2 rounded-lg text-sm font-semibold bg-hbrk hover:opacity-90 transition-opacity cursor-pointer"
            style="color:#0d0f14;">
            Criar Condomínio
        </button>
        <button type="button"
            onclick="document.getElementById('form-novo-condo').classList.add('hidden'); document.getElementById('btn-novo-condo').classList.remove('hidden');"
            class="px-4 py-2 rounded-lg text-sm text-slate-400 hover:text-slate-200 border border-hrim hover:border-slate-600 transition-colors cursor-pointer">
            Cancelar
        </button>
    </div>
</form>

<div class="bg-hsurf rounded-2xl border border-hrim overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-hrim">
                    <th class="px-5 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Nome</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Endereço</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Unidades</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">OS Ativa</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wide">Progresso</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-hrim">
                @foreach (var c in lista)
                {
                    var pct      = c.TryGetProperty("progresso",     out var pEl)  ? pEl.GetInt32()     : 0;
                    var osAtiva  = c.TryGetProperty("osAtiva",       out var oaEl) && oaEl.GetBoolean();
                    var nome     = c.GetProperty("nome").GetString()                ?? "";
                    var endereco = c.TryGetProperty("endereco", out var eEl) && eEl.ValueKind != JsonValueKind.Null
                                    ? eEl.GetString() ?? "" : "";
                    var totalUnidades = c.TryGetProperty("totalUnidades", out var tuEl) ? tuEl.GetInt32() : 0;
                    var barColor = pct == 100 ? "#00c9a7" : "#3b82f6";

                    <tr class="hover:bg-hcard/40 transition-colors">
                        <td class="px-5 py-3.5 font-medium text-slate-200">@nome</td>
                        <td class="px-5 py-3.5 text-slate-500 text-xs">@endereco</td>
                        <td class="px-5 py-3.5 text-slate-400">@totalUnidades</td>
                        <td class="px-5 py-3.5">
                            @if (osAtiva)
                            {
                                <span class="text-xs bg-hbrk/15 text-hbrk border border-hbrk/30 px-2 py-0.5 rounded-full">Aberta</span>
                            }
                            else
                            {
                                <span class="text-xs bg-slate-500/15 text-slate-500 border border-slate-500/30 px-2 py-0.5 rounded-full">Sem OS</span>
                            }
                        </td>
                        <td class="px-5 py-3.5 min-w-[120px]">
                            <div class="flex items-center gap-2">
                                <div class="flex-1 bg-hcard rounded-full h-1.5 overflow-hidden">
                                    <div class="h-1.5 rounded-full" style="width:@(pct)%; background-color:@barColor;"></div>
                                </div>
                                <span class="text-xs text-slate-500 w-8 text-right">@pct%</span>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!lista.Any())
        {
            <div class="text-center py-12">
                <p class="text-slate-500 text-sm">Nenhum condomínio cadastrado.</p>
            </div>
        }
    </div>
</div>
