@{
    ViewData["Title"] = "Dashboard";
    var erroViewBag  = ViewBag.Erro as string;
    var operadores   = ViewBag.Operadores as IEnumerable<dynamic>;

    JsonElement? d = Model is JsonElement je ? je : (JsonElement?)null;

    int GetInt(string key) =>
        d.HasValue && d.Value.TryGetProperty(key, out var v) ? v.GetInt32() : 0;

    var totalCondominios   = GetInt("totalCondominios");
    var totalUnidades      = GetInt("totalUnidades");
    var ordensAbertas      = GetInt("ordensAbertas");
    var suspeitasCount     = GetInt("suspeitasVazamento");
    var leiturasNoMes      = GetInt("leiturasNoMes");
    var leiturasIa         = GetInt("leiturasIa");
    var leiturasManual     = GetInt("leiturasManual");
    var totalUsuarios      = GetInt("totalUsuarios");
    var ordensNoMes        = GetInt("ordensNoMes");
}

@* ── Error banner ──────────────────────────────────────────────── *@
@if (!string.IsNullOrEmpty(erroViewBag))
{
    <div class="bg-red-500/10 border border-red-500/30 rounded-xl px-4 py-3 mb-6 flex items-center gap-3">
        <svg class="w-5 h-5 text-red-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <p class="text-sm text-red-400">@erroViewBag</p>
    </div>
}

@* ── Page header ───────────────────────────────────────────────── *@
<div class="mb-8">
    <h1 class="font-syne font-bold text-2xl text-slate-100">Dashboard</h1>
    <p class="text-slate-500 text-sm mt-1">Visão geral do sistema · @DateTime.Now.ToString("MMMM yyyy")</p>
</div>

@if (d.HasValue)
{
    @* ── KPI row 1: primary metrics ──────────────────────────────── *@
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-4">

        @* Condomínios *@
        <div class="bg-hsurf rounded-2xl border border-hrim p-5 hover:border-slate-600 transition-colors">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Condomínios</span>
                <div class="w-8 h-8 rounded-lg bg-blue-500/10 flex items-center justify-center">
                    <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 21h18M5 21V7l8-4 8 4v14M9 21V9h6v12"/>
                    </svg>
                </div>
            </div>
            <p class="text-3xl font-syne font-bold text-slate-100">@totalCondominios</p>
        </div>

        @* Unidades Ativas *@
        <div class="bg-hsurf rounded-2xl border border-hrim p-5 hover:border-slate-600 transition-colors">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Unidades</span>
                <div class="w-8 h-8 rounded-lg bg-violet-500/10 flex items-center justify-center">
                    <svg class="w-4 h-4 text-violet-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/>
                        <rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                    </svg>
                </div>
            </div>
            <p class="text-3xl font-syne font-bold text-slate-100">@totalUnidades</p>
        </div>

        @* OS Abertas *@
        <div class="bg-hsurf rounded-2xl border border-hrim p-5 hover:border-slate-600 transition-colors">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide">OS Abertas</span>
                <div class="w-8 h-8 rounded-lg bg-amber-500/10 flex items-center justify-center">
                    <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
                    </svg>
                </div>
            </div>
            <p class="text-3xl font-syne font-bold text-slate-100">@ordensAbertas</p>
        </div>

        @* Suspeitas de Vazamento *@
        <div class="bg-hsurf rounded-2xl border @(suspeitasCount > 0 ? "border-red-500/30" : "border-hrim") p-5 hover:border-slate-600 transition-colors">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Vazamentos</span>
                <div class="w-8 h-8 rounded-lg @(suspeitasCount > 0 ? "bg-red-500/15" : "bg-red-500/10") flex items-center justify-center">
                    <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 2c-4 4.5-6 7.5-6 10a6 6 0 0012 0c0-2.5-2-5.5-6-10z"/>
                        <path d="M12 12v4"/>
                    </svg>
                </div>
            </div>
            <p class="text-3xl font-syne font-bold @(suspeitasCount > 0 ? "text-red-400" : "text-slate-100")">@suspeitasCount</p>
            @if (suspeitasCount > 0)
            {
                <p class="text-xs text-red-500 mt-1">Requer atenção</p>
            }
        </div>

    </div>

    @* ── KPI row 2: secondary metrics ────────────────────────────── *@
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">

        @* Leituras no mês *@
        <div class="bg-hsurf rounded-2xl border border-hrim p-5">
            <div class="flex items-center justify-between mb-1">
                <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Leituras no mês</span>
                <svg class="w-4 h-4 text-hbrk" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                </svg>
            </div>
            <p class="text-3xl font-syne font-bold text-slate-100 mb-3">@leiturasNoMes</p>
            <div class="flex gap-2">
                <span class="text-xs bg-blue-500/10 text-blue-400 border border-blue-500/20 px-2.5 py-1 rounded-full flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="3"/><path d="M12 2v2m0 16v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M2 12h2m16 0h2"/>
                    </svg>
                    IA: @leiturasIa
                </span>
                <span class="text-xs bg-hbrk/10 text-hbrk border border-hbrk/20 px-2.5 py-1 rounded-full flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
                    </svg>
                    Manual: @leiturasManual
                </span>
            </div>
        </div>

        @* Usuários ativos *@
        <div class="bg-hsurf rounded-2xl border border-hrim p-5">
            <div class="flex items-center justify-between mb-1">
                <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Usuários ativos</span>
                <svg class="w-4 h-4 text-violet-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/>
                </svg>
            </div>
            <p class="text-3xl font-syne font-bold text-slate-100">@totalUsuarios</p>
        </div>

        @* OS no mês *@
        <div class="bg-hsurf rounded-2xl border border-hrim p-5">
            <div class="flex items-center justify-between mb-1">
                <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide">OS criadas no mês</span>
                <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            </div>
            <p class="text-3xl font-syne font-bold text-slate-100">@ordensNoMes</p>
        </div>

    </div>

    @* ── Operadores ──────────────────────────────────────────────── *@
    @if (operadores != null)
    {
        <div class="bg-hsurf rounded-2xl border border-hrim overflow-hidden mb-6">
            <div class="px-5 py-4 border-b border-hrim flex items-center justify-between">
                <h2 class="font-syne font-semibold text-slate-300 text-sm">Operadores — Progresso do Mês</h2>
                <span class="text-xs text-slate-600">@operadores.Count() ativos</span>
            </div>
            <div class="divide-y divide-hrim">
                @foreach (var op in operadores)
                {
                    var pctOp    = (int)(op.progresso    ?? 0);
                    var nomeOp   = (string)(op.nome      ?? "?");
                    var inicialOp = nomeOp.Length > 0 ? nomeOp[0].ToString().ToUpper() : "?";
                    var barColor = pctOp >= 90 ? "#00c9a7" : pctOp >= 60 ? "#3b82f6" : "#f59e0b";
                    var pctColor = pctOp >= 90 ? "text-hbrk" : pctOp >= 60 ? "text-blue-400" : "text-amber-400";

                    <div class="px-5 py-4 flex items-center gap-4">
                        <div class="w-9 h-9 rounded-lg bg-hbrk/15 flex items-center justify-center shrink-0">
                            <span class="text-sm font-bold font-syne text-hbrk">@inicialOp</span>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center justify-between mb-1.5">
                                <p class="text-sm font-medium text-slate-200">@nomeOp</p>
                                <span class="text-xs font-semibold @pctColor">@pctOp%</span>
                            </div>
                            <div class="w-full bg-hcard rounded-full h-1.5 overflow-hidden">
                                <div class="h-1.5 rounded-full transition-all"
                                     style="width:@(pctOp)%; background-color:@barColor;"></div>
                            </div>
                            <p class="text-xs text-slate-600 mt-1">
                                Conds @(op.condominiosMin)–@(op.condominiosMax)
                            </p>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @* ── Quick actions ────────────────────────────────────────────── *@
    <div class="flex gap-3">
        <a href="/Admin/Auditoria"
           class="flex items-center gap-2 text-sm font-semibold px-4 py-2.5 rounded-lg border transition-colors
                  bg-hcard text-slate-300 border-hrim hover:border-slate-500 hover:text-slate-100">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
            </svg>
            Ver Auditoria
        </a>
    </div>
}
else
{
    <div class="bg-hsurf rounded-2xl border border-hrim p-16 text-center">
        <div class="w-14 h-14 rounded-2xl bg-hcard border border-hrim flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-slate-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="12" width="5" height="9" rx="1"/><rect x="9.5" y="7" width="5" height="14" rx="1"/><rect x="16" y="3" width="5" height="18" rx="1"/>
            </svg>
        </div>
        <p class="text-slate-400 font-medium">Não foi possível carregar as estatísticas</p>
        <p class="text-slate-600 text-sm mt-1">Verifique se a API está disponível.</p>
    </div>
}
