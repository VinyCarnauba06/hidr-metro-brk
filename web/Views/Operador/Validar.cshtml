@{
    ViewData["Title"] = "Validar Leituras";
    var osId    = ViewBag.OsId as int? ?? 0;
    var leituras = (IEnumerable<JsonElement>)Model;
    var erroApi  = ViewBag.Erro     as string;
    var erroTemp = TempData["Erro"] as string;

    // ViewBag.Progresso é JsonElement (API) ou JsonElement (mock)
    JsonElement? progresso = ViewBag.Progresso is JsonElement jp ? jp : (JsonElement?)null;
    var total      = progresso?.GetProperty("totalUnidades").GetInt32()      ?? 0;
    var registradas = progresso?.GetProperty("leiturasRegistradas").GetInt32() ?? 0;
    var faltando   = progresso?.GetProperty("faltandoRegistrar").GetInt32()  ?? 0;
    var pct        = total > 0 ? (int)((double)registradas / total * 100) : 0;
}

@* ── Error banners ─────────────────────────────────────────────── *@
@if (!string.IsNullOrEmpty(erroApi))
{
    <div class="bg-red-500/10 border border-red-500/30 rounded-xl px-4 py-3 mb-6 flex items-center gap-3">
        <svg class="w-5 h-5 text-red-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <p class="text-sm text-red-400">@erroApi</p>
    </div>
}
@if (!string.IsNullOrEmpty(erroTemp))
{
    <div class="bg-amber-500/10 border border-amber-500/30 rounded-xl px-4 py-3 mb-6 flex items-center gap-3">
        <svg class="w-5 h-5 text-amber-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
        <p class="text-sm text-amber-400">@erroTemp</p>
    </div>
}

@* ── Page header ───────────────────────────────────────────────── *@
<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="font-syne font-bold text-2xl text-slate-100">Validar Leituras</h1>
        <p class="text-slate-500 text-sm mt-1">OS #@osId</p>
    </div>
    <a href="/Operador"
       class="flex items-center gap-1.5 text-sm text-slate-400 hover:text-slate-200 transition-colors border border-hrim rounded-lg px-3 py-1.5 hover:border-slate-600">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
        Voltar
    </a>
</div>

@* ── Progress card ─────────────────────────────────────────────── *@
@if (progresso.HasValue)
{
    <div class="bg-hsurf rounded-2xl border border-hrim p-5 mb-6">
        <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-slate-300">Progresso da OS</span>
                @if (faltando == 0)
                {
                    <span class="text-xs bg-hbrk/15 text-hbrk border border-hbrk/30 px-2 py-0.5 rounded-full">100% completo</span>
                }
            </div>
            <span class="text-lg font-syne font-bold @(pct == 100 ? "text-hbrk" : "text-slate-300")">@pct%</span>
        </div>
        <div class="w-full bg-hcard rounded-full h-2 overflow-hidden mb-2">
            <div class="h-2 rounded-full transition-all duration-700"
                 style="width:@(pct)%; background-color:@(pct == 100 ? "#00c9a7" : "#3b82f6");"></div>
        </div>
        <p class="text-xs text-slate-500">
            @registradas de @total unidades registradas
            @if (faltando > 0) { <span> — @faltando ainda sem leitura</span> }
        </p>
    </div>
}

@* ── Export buttons (only when 100%) ──────────────────────────── *@
@if (faltando == 0 && progresso.HasValue)
{
    <div class="flex gap-3 mb-6">
        <a href="/Operador/GerarExcel?osId=@osId"
           class="flex items-center gap-2 text-sm font-semibold px-4 py-2 rounded-lg border transition-colors
                  bg-hbrk/10 text-hbrk border-hbrk/30 hover:bg-hbrk hover:border-hbrk"
           onmouseover="this.style.color='#0d0f14'" onmouseout="this.style.color=''">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
            </svg>
            Baixar Excel
        </a>
        <a href="/Operador/GerarPdf?osId=@osId"
           class="flex items-center gap-2 text-sm font-semibold px-4 py-2 rounded-lg border transition-colors
                  bg-red-500/10 text-red-400 border-red-500/30 hover:bg-red-500 hover:border-red-500 hover:text-white">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/>
            </svg>
            Baixar PDF
        </a>
    </div>
}

@* ── Reading cards ─────────────────────────────────────────────── *@
<div class="space-y-4">

    @foreach (var leitura in leituras)
    {
        var lId          = leitura.GetProperty("id").GetInt32();
        var numeroUnidade = leitura.GetProperty("numeroUnidade").GetString() ?? "";
        var valorM3      = leitura.GetProperty("valorM3").GetDecimal();
        var origem       = leitura.GetProperty("origem").GetString() ?? "";
        var status       = leitura.GetProperty("status").GetString() ?? "";
        var isVazamento  = leitura.GetProperty("suspeitaVazamento").GetBoolean();
        var confiancaEl  = leitura.GetProperty("confiancaIa");
        var temConfianca = confiancaEl.ValueKind != JsonValueKind.Null;
        // A API não expõe fotoPath; mostra imagem quando a origem é IA (foto enviada pelo app)
        var temFoto      = origem == "Ia";

        string borderColor = status == "Validado"  ? "#00c9a7" :
                             status == "Rejeitado"  ? "#ef4444" :
                             status == "Corrigido"  ? "#3b82f6" : "#f59e0b";

        string cardBg = isVazamento ? "bg-red-950/20 border-red-500/40" : "bg-hsurf border-hrim";

        string statusCls = status == "Validado"  ? "bg-hbrk/15 text-hbrk border border-hbrk/30" :
                           status == "Rejeitado"  ? "bg-red-500/15 text-red-400 border border-red-500/30" :
                           status == "Corrigido"  ? "bg-blue-500/15 text-blue-400 border border-blue-500/30" :
                                                    "bg-amber-500/15 text-amber-400 border border-amber-500/30";

        <div class="rounded-2xl border @cardBg overflow-hidden"
             style="border-left: 3px solid @borderColor;">

            <div class="grid grid-cols-1 md:grid-cols-2">

                @* Left: Photo *@
                <div class="bg-hcard flex items-center justify-center min-h-48 p-4 border-b md:border-b-0 md:border-r border-hrim">
                    @if (temFoto)
                    {
                        <img src="/api/operador/leituras/@lId/foto"
                             class="max-h-56 w-full rounded-lg object-contain"
                             alt="Foto unidade @numeroUnidade"
                             onerror="this.onerror=null;this.parentElement.innerHTML='<p class=\'text-slate-500 text-sm text-center\'>Foto indisponível</p>';" />
                    }
                    else
                    {
                        <div class="text-center">
                            <svg class="w-12 h-12 text-slate-700 mx-auto mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/>
                                <polyline points="21 15 16 10 5 21"/>
                            </svg>
                            <p class="text-slate-500 text-sm">Sem foto (entrada manual)</p>
                        </div>
                    }
                </div>

                @* Right: Data + Actions *@
                <div class="p-5 flex flex-col gap-3">

                    <div class="flex items-center justify-between">
                        <p class="font-syne font-semibold text-slate-100 text-lg">Unidade @numeroUnidade</p>
                        <span class="text-xs px-2.5 py-1 rounded-full @statusCls">@status</span>
                    </div>

                    <div>
                        <p class="text-xs text-slate-500 mb-0.5">Valor extraído pela IA</p>
                        <p class="text-3xl font-syne font-bold text-hbrk">@valorM3 <span class="text-lg text-slate-400 font-dm font-normal">m³</span></p>
                        @if (temConfianca)
                        {
                            <p class="text-xs text-slate-600 mt-0.5">
                                Confiança: @($"{confiancaEl.GetDouble() * 100:F0}")% · Origem: @origem
                            </p>
                        }
                    </div>

                    @if (isVazamento)
                    {
                        <div class="bg-red-500/10 border border-red-500/30 rounded-lg p-3 flex items-start gap-2">
                            <svg class="w-4 h-4 text-red-400 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 6a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 6zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
                            </svg>
                            <div>
                                <p class="text-red-400 text-xs font-semibold">Suspeita de Vazamento</p>
                                <p class="text-red-500/80 text-xs">Consumo acima da média histórica. Verificar antes de aprovar.</p>
                            </div>
                        </div>
                    }

                    @if (status == "Pendente")
                    {
                        <div class="grid grid-cols-3 gap-2 pt-1 mt-auto">

                            <form method="post" action="/Operador/AprovarLeitura">
                                <input type="hidden" name="id"   value="@lId" />
                                <input type="hidden" name="osId" value="@osId" />
                                <button type="submit"
                                    class="w-full py-2 rounded-lg text-sm font-semibold border transition-colors
                                           bg-hbrk/10 text-hbrk border-hbrk/30 hover:bg-hbrk hover:border-hbrk cursor-pointer"
                                    onmouseover="this.style.color='#0d0f14'" onmouseout="this.style.color=''">
                                    Aprovar
                                </button>
                            </form>

                            <button onclick="abrirCorrecao(@lId, @osId)"
                                class="py-2 rounded-lg text-sm font-semibold border transition-colors cursor-pointer
                                       bg-blue-500/10 text-blue-400 border-blue-500/30 hover:bg-blue-500 hover:border-blue-500 hover:text-white">
                                Corrigir
                            </button>

                            <button onclick="abrirRejeicao(@lId, @osId)"
                                class="py-2 rounded-lg text-sm font-semibold border transition-colors cursor-pointer
                                       bg-red-500/10 text-red-400 border-red-500/30 hover:bg-red-500 hover:border-red-500 hover:text-white">
                                Rejeitar
                            </button>

                        </div>
                    }

                </div>
            </div>
        </div>
    }

    @if (!leituras.Any())
    {
        <div class="bg-hsurf rounded-2xl border border-hrim p-16 text-center">
            <p class="text-slate-500">Nenhuma leitura encontrada para esta OS.</p>
        </div>
    }

</div>

@* ── Modal: Corrigir ───────────────────────────────────────────── *@
<div id="modalCorrecao" class="hidden fixed inset-0 bg-black/70 backdrop-blur-sm flex items-center justify-center z-50 p-4">
    <div class="bg-hsurf rounded-2xl border border-hrim w-full max-w-md shadow-2xl">
        <div class="flex items-center justify-between px-6 pt-6 pb-4 border-b border-hrim">
            <h3 class="font-syne font-semibold text-slate-100 text-lg">Corrigir Leitura</h3>
            <button onclick="fecharModal('modalCorrecao')"
                class="text-slate-500 hover:text-slate-300 transition-colors cursor-pointer">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>
        <form method="post" action="/Operador/CorrigirLeitura" class="p-6 space-y-4">
            <input type="hidden" id="correcaoId"   name="id" />
            <input type="hidden" id="correcaoOsId" name="osId" />
            <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Valor Correto (m³)</label>
                <input name="valorCorrigido" type="number" step="0.01" min="0" required
                    class="w-full bg-hcard border border-hrim rounded-lg px-4 py-2.5 text-slate-200 text-sm
                           focus:outline-none focus:border-hbrk focus:ring-1 focus:ring-hbrk transition-colors" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Observação <span class="normal-case font-normal">(opcional)</span></label>
                <textarea name="observacao" rows="3"
                    class="w-full bg-hcard border border-hrim rounded-lg px-4 py-2.5 text-slate-200 text-sm resize-none
                           focus:outline-none focus:border-hbrk focus:ring-1 focus:ring-hbrk transition-colors"
                    placeholder="Descreva o motivo da correção..."></textarea>
            </div>
            <div class="flex gap-2 pt-2">
                <button type="button" onclick="fecharModal('modalCorrecao')"
                    class="flex-1 py-2.5 rounded-lg text-sm border border-hrim text-slate-400 hover:text-slate-200 hover:border-slate-600 transition-colors cursor-pointer">
                    Cancelar
                </button>
                <button type="submit"
                    class="flex-1 py-2.5 rounded-lg text-sm font-semibold bg-blue-600 text-white hover:bg-blue-500 transition-colors cursor-pointer">
                    Salvar Correção
                </button>
            </div>
        </form>
    </div>
</div>

@* ── Modal: Rejeitar ───────────────────────────────────────────── *@
<div id="modalRejeicao" class="hidden fixed inset-0 bg-black/70 backdrop-blur-sm flex items-center justify-center z-50 p-4">
    <div class="bg-hsurf rounded-2xl border border-hrim w-full max-w-md shadow-2xl">
        <div class="flex items-center justify-between px-6 pt-6 pb-4 border-b border-hrim">
            <h3 class="font-syne font-semibold text-slate-100 text-lg">Rejeitar Leitura</h3>
            <button onclick="fecharModal('modalRejeicao')"
                class="text-slate-500 hover:text-slate-300 transition-colors cursor-pointer">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
        </div>
        <form method="post" action="/Operador/RejeitarLeitura" class="p-6 space-y-4">
            <input type="hidden" id="rejeicaoId"   name="id" />
            <input type="hidden" id="rejeicaoOsId" name="osId" />
            <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Motivo da Rejeição <span class="text-red-400">*</span></label>
                <textarea name="motivoRejeicao" rows="4" required
                    class="w-full bg-hcard border border-hrim rounded-lg px-4 py-2.5 text-slate-200 text-sm resize-none
                           focus:outline-none focus:border-red-500 focus:ring-1 focus:ring-red-500 transition-colors"
                    placeholder="Explique o motivo da rejeição..."></textarea>
            </div>
            <div class="flex gap-2 pt-2">
                <button type="button" onclick="fecharModal('modalRejeicao')"
                    class="flex-1 py-2.5 rounded-lg text-sm border border-hrim text-slate-400 hover:text-slate-200 hover:border-slate-600 transition-colors cursor-pointer">
                    Cancelar
                </button>
                <button type="submit"
                    class="flex-1 py-2.5 rounded-lg text-sm font-semibold bg-red-600 text-white hover:bg-red-500 transition-colors cursor-pointer">
                    Confirmar Rejeição
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function abrirCorrecao(id, osId) {
        document.getElementById('correcaoId').value   = id;
        document.getElementById('correcaoOsId').value = osId;
        document.getElementById('modalCorrecao').classList.remove('hidden');
    }
    function abrirRejeicao(id, osId) {
        document.getElementById('rejeicaoId').value   = id;
        document.getElementById('rejeicaoOsId').value = osId;
        document.getElementById('modalRejeicao').classList.remove('hidden');
    }
    function fecharModal(id) {
        document.getElementById(id).classList.add('hidden');
    }
    // Close on backdrop click
    ['modalCorrecao', 'modalRejeicao'].forEach(id => {
        document.getElementById(id)?.addEventListener('click', function(e) {
            if (e.target === this) fecharModal(id);
        });
    });
</script>
}
