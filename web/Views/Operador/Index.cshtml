@{
    ViewData["Title"] = "Ordens de Serviço";
    var erroViewBag = ViewBag.Erro as string;
    var osList = (IEnumerable<JsonElement>)Model;
}

@* ── Error banner ──────────────────────────────────────────────── *@
@if (!string.IsNullOrEmpty(erroViewBag))
{
    <div class="bg-red-500/10 border border-red-500/30 rounded-xl px-4 py-3 mb-6 flex items-center gap-3">
        <svg class="w-5 h-5 text-red-400 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <p class="text-sm text-red-400">@erroViewBag</p>
    </div>
}

@* ── Page header ───────────────────────────────────────────────── *@
<div class="mb-8 flex items-end justify-between">
    <div>
        <h1 class="font-syne font-bold text-2xl text-slate-100">Ordens de Serviço</h1>
        <p class="text-slate-500 text-sm mt-1">Leituras aguardando validação</p>
    </div>
    @if (osList.Any())
    {
        <span class="text-xs text-slate-500 bg-hcard border border-hrim px-3 py-1 rounded-full">
            @osList.Count() OS encontrada(s)
        </span>
    }
</div>

@* ── Empty state ───────────────────────────────────────────────── *@
@if (!osList.Any())
{
    <div class="bg-hsurf rounded-2xl border border-hrim p-16 text-center">
        <div class="w-14 h-14 rounded-2xl bg-hcard border border-hrim flex items-center justify-center mx-auto mb-4">
            <svg width="28" height="28" class="w-7 h-7 text-slate-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
        </div>
        <p class="text-slate-400 font-medium">Nenhuma OS aguardando validação</p>
        <p class="text-slate-600 text-sm mt-1">Todas as ordens estão concluídas ou sem leituras pendentes.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
        @foreach (var os in osList)
        {
            var total      = os.GetProperty("totalLeituras").GetInt32();
            var validadas  = os.GetProperty("leiturasValidadas").GetInt32();
            var pendentes  = os.GetProperty("leiturasPendentes").GetInt32();
            var vazamentos = os.GetProperty("suspeitasVazamento").GetInt32();
            var pct        = total > 0 ? (int)((double)validadas / total * 100) : 0;
            var condo      = os.GetProperty("condominio").GetString() ?? "";
            var mes        = os.GetProperty("mes").GetInt32();
            var ano        = os.GetProperty("ano").GetInt32();
            var osId       = os.GetProperty("id").GetInt32();

            string badgeCls, badgeTxt;
            if (vazamentos > 0)
            {
                badgeCls = "bg-red-500/15 text-red-400 border border-red-500/30";
                badgeTxt = "Vazamento";
            }
            else if (pendentes > 0)
            {
                badgeCls = "bg-amber-500/15 text-amber-400 border border-amber-500/30";
                badgeTxt = "Pendente";
            }
            else
            {
                badgeCls = "bg-hbrk/15 text-hbrk border border-hbrk/30";
                badgeTxt = "Completo";
            }

            <div class="bg-hsurf rounded-2xl border border-hrim hover:border-slate-600 transition-colors duration-200 p-5 flex flex-col gap-4">

                @* Header *@
                <div class="flex items-start justify-between gap-2">
                    <div class="min-w-0">
                        <p class="font-syne font-semibold text-slate-100 truncate">@condo</p>
                        <p class="text-xs text-slate-500 mt-0.5">Competência @mes/@ano</p>
                    </div>
                    <span class="text-xs px-2.5 py-1 rounded-full border flex-shrink-0 @badgeCls">
                        @badgeTxt
                    </span>
                </div>

                @* Progress bar *@
                <div>
                    <div class="flex justify-between text-xs mb-1.5">
                        <span class="text-slate-500">@validadas de @total leituras</span>
                        <span class="font-semibold @(pct == 100 ? "text-hbrk" : "text-slate-400")">@pct%</span>
                    </div>
                    <div class="w-full bg-hcard rounded-full h-1.5 overflow-hidden">
                        <div class="h-1.5 rounded-full transition-all duration-500"
                             style="width:@(pct)%; background-color:@(pct == 100 ? "#00c9a7" : "#3b82f6");"></div>
                    </div>
                </div>

                @* Footer *@
                <div class="flex items-center justify-between pt-1">
                    <div class="flex gap-3 text-xs">
                        @if (vazamentos > 0)
                        {
                            <span class="flex items-center gap-1 text-red-400">
                                <svg width="14" height="14" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 6a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 6zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
                                </svg>
                                @vazamentos suspeita(s)
                            </span>
                        }
                        @if (pendentes > 0)
                        {
                            <span class="text-slate-500">@pendentes pendente(s)</span>
                        }
                    </div>
                    <a href="/Operador/Validar?osId=@osId"
                       class="text-xs font-semibold px-4 py-1.5 rounded-lg border transition-colors duration-150
                              bg-hbrk/10 text-hbrk border-hbrk/30 hover:bg-hbrk hover:border-hbrk"
                       style="--tw-hover-text: #0d0f14;"
                       onmouseover="this.style.color='#0d0f14'"
                       onmouseout="this.style.color=''">
                        Validar
                    </a>
                </div>

            </div>
        }
    </div>
}
